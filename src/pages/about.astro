---
import Layout from '../layouts/Layout.astro'
---

<Layout title="About – Creative Designer">
  <div class="intro-scroll">
    <p>Scroll to explore</p>
  </div>

  <div class="lines-container">
    <div class="line">
      <span>I craft</span>
      <span class="img-span">
        <img src="https://i.pinimg.com/1200x/93/27/65/932765c7cd00055218ba7398119d7d4d.jpg" alt="" />
      </span>
    </div>
    <div class="line">
      <span>products and</span>
      <span class="img-span">
        <img src="https://i.pinimg.com/736x/a9/f1/19/a9f11909a9644d7bfd5102fabcd8310c.jpg" alt="" />
      </span>
    </div>
    <div class="line">
      <span>websites rooted</span>
      <span class="img-span">
        <img src="https://i.pinimg.com/1200x/48/09/77/480977567d6b4503c8f642728f266b72.jpg" alt="" />
      </span>
    </div>
    <div class="line">
      <span>in clarity</span>
    </div>
    <div class="line">
      <span>and quiet</span>
      <span class="img-span">
        <img src="https://i.pinimg.com/1200x/9e/f2/b7/9ef2b73b1e2ff489f99bc0a90196fbea.jpg" alt="" />
      </span>
    </div>
    <div class="line">
      <span>confidence.</span>
    </div>
  </div>

  <section class="page-about">
    <div class="page__inner">
      <p>For over 6 years, I've collaborated with founders, studios, and product teams across Europe, Africa, and the US to design products and websites rooted in clarity and quiet confidence.</p>

      <p>I've led a full brand and website refresh for a San Francisco start-up to improve clarity and conversion, and driven product design across core workflows while building a scalable Design System for a Munich SaaS company.</p>
    </div>
  </section>
</Layout>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  window.addEventListener('load', () => {
    document.querySelectorAll('.line').forEach((line) => {
      const imgSpan = line.querySelector('.img-span')
      if (imgSpan) {
        gsap.to(imgSpan, {
          width: 300,
          ease: 'none',
          scrollTrigger: {
            trigger: line,
            start: 'top 90%',
            end: 'top 40%',
            scrub: 1,
          },
        })
      }
    })
  })
</script>

<style lang="scss">
  .intro-scroll {
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;

    p {
      font: 300 0.875rem / 1 'Inter', sans-serif;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: color(secondary);
      opacity: 0.5;
    }
  }

  .lines-container {
    padding: 0 2rem;

    .line {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;

      span {
        font: 700 7.5rem / 1 font-family(bigger);
        letter-spacing: -4px;
        display: inline-block;

        @include mq(tablet) {
          font-size: 4rem;
          letter-spacing: -2px;
        }

        @include mq(phone) {
          font-size: 2.5rem;
          letter-spacing: -1px;
        }
      }
    }

    .img-span {
      height: 110px;
      width: 0;
      border-radius: 5px;
      overflow: hidden;
      position: relative;

      @include mq(phone) {
        height: 60px;
      }

      img {
        height: 100%;
        width: 300px;
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        border-radius: 5px;
        object-fit: cover;
        object-position: center center;

        @include mq(phone) {
          width: 160px;
        }
      }
    }
  }

  .page-about {
    min-height: 100vh;
    padding: 6rem 2rem;
    display: flex;
    align-items: center;
    justify-content: center;

    .page__inner {
      max-width: 40rem;

      p {
        font: 200 1.5rem / 1.7 font-family(editorial);
        color: color(secondary);
        margin: 0 0 2rem;

        &:last-child {
          margin: 0;
        }
      }
    }
  }
</style>
