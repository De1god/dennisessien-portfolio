---
import Layout from '../../layouts/Layout.astro'
---

<Layout title="Xtoken – Work">
  <section class="project-detail">
    <div class="project-detail__inner">
      <a href="/work" class="project-detail__back">← Back</a>

      <div class="project-detail__header">
        <div class="project-detail__thumb">
          <img src="/images/projects/xtoken.webp" alt="Xtoken" />
        </div>
        <div class="project-detail__intro">
          <h1 class="project-detail__title">Xtoken</h1>
          <p class="project-detail__tagline">A DAO platform</p>
        </div>
      </div>

      <div class="project-detail__meta">
        <div class="project-detail__meta-item">
          <span class="project-detail__meta-label">Year</span>
          <span class="project-detail__meta-value">2021</span>
        </div>
        <div class="project-detail__meta-item">
          <span class="project-detail__meta-label">Industry</span>
          <span class="project-detail__meta-value">Web3</span>
        </div>
        <div class="project-detail__meta-item">
          <span class="project-detail__meta-label">Service</span>
          <span class="project-detail__meta-value">Ui/Ux Design</span>
        </div>
      </div>

      <div class="project-detail__content">
        <p>xToken is a decentralized platform for simple and efficient staking and liquidity strategies which allows users to participate in multiple investment strategies.</p>
        <p>My primary goal was to create an experience/interface that will be easily understood by the users, and that provided them with the tools and information they needed to effectively use the terminal.</p>
      </div>

      <div class="project-detail__gallery">
        <div class="project-detail__grid project-detail__grid--2x2">
          <img src="/images/projects/xtoken/desktop view1.webp" alt="Desktop view 1" />
          <img src="/images/projects/xtoken/desktop view2.webp" alt="Desktop view 2" />
          <img src="/images/projects/xtoken/desktop view3.webp" alt="Desktop view 3" />
          <img src="/images/projects/xtoken/desktop view4.webp" alt="Desktop view 4" />
        </div>
        <div class="project-detail__grid project-detail__grid--3x2">
          <img src="/images/projects/xtoken/desktop modal1.webp" alt="Desktop modal 1" />
          <img src="/images/projects/xtoken/desktop modal2.webp" alt="Desktop modal 2" />
          <img src="/images/projects/xtoken/desktop modal3.webp" alt="Desktop modal 3" />
          <img src="/images/projects/xtoken/desktop modal4.avif" alt="Desktop modal 4" />
          <img src="/images/projects/xtoken/desktop modal5.webp" alt="Desktop modal 5" />
          <img src="/images/projects/xtoken/desktop modal6.webp" alt="Desktop modal 6" />
        </div>
        <div class="project-detail__grid project-detail__grid--5">
          <img src="/images/projects/xtoken/mobile%20modals%20(1).webp" alt="Mobile modal 1" />
          <img src="/images/projects/xtoken/mobile%20modals%20(2).webp" alt="Mobile modal 2" />
          <img src="/images/projects/xtoken/mobile%20modals%20(3).webp" alt="Mobile modal 3" />
          <img src="/images/projects/xtoken/mobile%20modals%20(4).webp" alt="Mobile modal 4" />
          <img src="/images/projects/xtoken/mobile%20modals%20(5).webp" alt="Mobile modal 5" />
          <img src="/images/projects/xtoken/mobile%20modals%20(6).webp" alt="Mobile modal 6" />
          <img src="/images/projects/xtoken/mobile%20modals%20(7).webp" alt="Mobile modal 7" />
          <img src="/images/projects/xtoken/mobile%20modals%20(8).webp" alt="Mobile modal 8" />
          <img src="/images/projects/xtoken/mobile%20modals%20(9).webp" alt="Mobile modal 9" />
          <img src="/images/projects/xtoken/mobile%20modals%20(10).webp" alt="Mobile modal 10" />
          <img src="/images/projects/xtoken/mobile%20modals%20(11).webp" alt="Mobile modal 11" />
          <img src="/images/projects/xtoken/mobile%20modals%20(12).webp" alt="Mobile modal 12" />
          <img src="/images/projects/xtoken/mobile%20modals%20(13).webp" alt="Mobile modal 13" />
          <img src="/images/projects/xtoken/mobile%20modals%20(14).webp" alt="Mobile modal 14" />
          <img src="/images/projects/xtoken/mobile%20modals%20(15).webp" alt="Mobile modal 15" />
          <img src="/images/projects/xtoken/mobile%20modals%20(16).webp" alt="Mobile modal 16" />
          <img src="/images/projects/xtoken/mobile%20modals%20(17).webp" alt="Mobile modal 17" />
          <img src="/images/projects/xtoken/mobile%20modals%20(18).webp" alt="Mobile modal 18" />
          <img src="/images/projects/xtoken/mobile%20modals%20(19).webp" alt="Mobile modal 19" />
          <img src="/images/projects/xtoken/mobile%20modals%20(20).webp" alt="Mobile modal 20" />
          <img src="/images/projects/xtoken/mobile%20modals%20(21).webp" alt="Mobile modal 21" />
          <img src="/images/projects/xtoken/mobile%20modals%20(22).webp" alt="Mobile modal 22" />
          <img src="/images/projects/xtoken/mobile%20modals%20(23).webp" alt="Mobile modal 23" />
          <img src="/images/projects/xtoken/mobile%20modals%20(24).webp" alt="Mobile modal 24" />
          <img src="/images/projects/xtoken/mobile%20modals%20(25).webp" alt="Mobile modal 25" />
          <img src="/images/projects/xtoken/mobile%20modals%20(26).webp" alt="Mobile modal 26" />
          <img src="/images/projects/xtoken/mobile%20modals%20(27).webp" alt="Mobile modal 27" />
          <img src="/images/projects/xtoken/mobile%20modals%20(28).webp" alt="Mobile modal 28" />
          <img src="/images/projects/xtoken/mobile%20modals%20(29).webp" alt="Mobile modal 29" />
        </div>
      </div>
    </div>
  </section>
</Layout>

<style lang="scss">
  .project-detail {
    padding: 4rem 2rem 6rem;

    &__inner {
      max-width: 50rem;
      margin: 0 auto;
    }

    &__back {
      display: inline-block;
      margin-bottom: 2rem;
      font: 400 0.875rem / 1 font-family(fraktion);
      color: color(secondary);
      opacity: 0.6;
      text-decoration: none;
      transition: opacity 0.2s;

      &:hover {
        opacity: 1;
      }
    }

    &__header {
      margin-bottom: 2.5rem;
    }

    &__thumb {
      width: 100%;
      max-height: 24rem;
      overflow: hidden;
      margin-bottom: 2rem;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
    }

    &__title {
      margin: 0 0 0.5rem;
      font: 700 3.5rem / 0.9 font-family(bigger);
      text-transform: uppercase;
      color: color(secondary);
    }

    &__tagline {
      margin: 0;
      font: 200 1.25rem / 1.5 font-family(editorial);
      color: color(secondary);
      opacity: 0.7;
    }

    &__meta {
      display: flex;
      gap: 3rem;
      margin-bottom: 3rem;
      padding: 1.5rem 0;
      border-top: 1px solid color(secondary);
      border-bottom: 1px solid color(secondary);
    }

    &__meta-item {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    &__meta-label {
      font: 700 0.7rem / 1 font-family(fraktion);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: color(secondary);
      opacity: 0.5;
    }

    &__meta-value {
      font: 400 1rem / 1 font-family(fraktion);
      color: color(secondary);
    }

    &__content {
      p {
        font: 200 1.25rem / 1.7 font-family(editorial);
        color: color(secondary);
        margin: 0 0 1.5rem;
      }
    }

    &__gallery {
      margin-top: 3rem;
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    &__grid {
      display: grid;
      gap: 1rem;

      img {
        width: 100%;
        border-radius: 4px;
      }

      &--2x2 {
        grid-template-columns: repeat(2, 1fr);
      }

      &--3x2 {
        grid-template-columns: repeat(3, 1fr);
      }

      &--5 {
        grid-template-columns: repeat(5, 1fr);
      }
    }
  }
</style>
