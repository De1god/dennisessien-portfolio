---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Work – Creative Designer">
  <section class="page-work">
    <div class="page__inner">
      <h1 class="page__title">Work</h1>
      <p class="page__intro">Selected projects that I've had the pleasure of working on.</p>

      <div class="page__grid">
        <a href="/work/xtoken" class="project">
          <div class="project__thumb" style="background: #1a1a2e;">
            <img src="/images/projects/xtoken.webp" alt="Xtoken" />
          </div>
          <div class="project__info">
            <h3 class="project__title">Xtoken</h3>
            <span class="project__tag">a dao platform</span>
          </div>
        </a>

        <a href="/work/netto" class="project">
          <div class="project__thumb" style="background: #16213e;">
            <img src="/images/projects/netto.webp" alt="Netto" />
          </div>
          <div class="project__info">
            <h3 class="project__title">Netto</h3>
            <span class="project__tag">a supermart chain on-boarding platform</span>
          </div>
        </a>

        <a href="/work/control-base" class="project">
          <div class="project__thumb" style="background: #0f3460;">
            <img src="/images/projects/control-base.webp" alt="Control Base" />
          </div>
          <div class="project__info">
            <h3 class="project__title">Control Base</h3>
            <span class="project__tag">Neo-Nigerian fashion eCommerce site</span>
          </div>
        </a>

        <a href="#" class="project">
          <div class="project__thumb" style="background: #533483;"></div>
          <div class="project__info">
            <h3 class="project__title">eDiye</h3>
            <span class="project__tag">Website/app development studio</span>
          </div>
        </a>

        <a href="#" class="project">
          <div class="project__thumb" style="background: #e94560;"></div>
          <div class="project__info">
            <h3 class="project__title">email</h3>
            <span class="project__tag">compilation of various email designs</span>
          </div>
        </a>

        <a href="#" class="project">
          <div class="project__thumb" style="background: #1a1a2e;"></div>
          <div class="project__info">
            <h3 class="project__title">LevChary</h3>
            <span class="project__tag">an edu-tech platform</span>
          </div>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style lang="scss">
  .page-work {
    padding: 6rem 2rem;

    .page__inner {
      max-width: 60rem;
      margin: 0 auto;
    }

    .page__title {
      margin: 0 0 1rem;
      font: 700 4rem / 0.9 font-family(bigger);
      text-transform: uppercase;
      color: color(secondary);
    }

    .page__intro {
      margin: 0 0 3rem;
      font: 200 1.25rem / 1.5 font-family(editorial);
      color: color(secondary);
    }

    .page__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: color(secondary);

      @include mq(tablet) {
        grid-template-columns: repeat(2, 1fr);
      }

      @include mq(phone) {
        grid-template-columns: 1fr;
      }
    }

    .project {
      display: block;
      background: color(primary);
      text-decoration: none;
      transition: opacity 0.3s ease;

      &:hover {
        opacity: 0.85;
      }

      &__thumb {
        aspect-ratio: 4 / 3;
        width: 100%;
        overflow: hidden;

        img {
          width: 100%;
          height: 100%;
          object-fit: cover;
        }
      }

      &__info {
        padding: 1rem;
        border-top: 1px solid color(secondary);
      }

      &__title {
        margin: 0 0 0.25rem;
        font: 700 1rem / 1.2 font-family(fraktion);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: color(secondary);
      }

      &__tag {
        font: 200 0.75rem / 1 font-family(editorial);
        color: color(secondary);
        opacity: 0.6;
      }
    }
  }
</style>
